# EBC NGO Platform — env template
# Copy to .env and fill in actual values

SUPABASE_PROJECT_REF=
SUPABASE_ORG_ID=
SUPABASE_REGION=eu-central-1

NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL_POOLER=
SUPABASE_DB_URL_DIRECT=
SUPABASE_ACCESS_TOKEN=

ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
RETELL_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Billing / invoicing (Fázis 3) — needs a registered Kft + ÁFA-szám to go live ---
BILLING_PROVIDER=          # none | szamlazzhu | billingo
BILLING_LIVE=             # 'true' to actually issue invoices (fail-closed otherwise)
SZAMLAZZHU_AGENT_KEY=      # Számlázz.hu "Számla Agent" kulcs
SELLER_NAME=              # Kft. cégnév (eladó)
SELLER_TAX_ID=            # ÁFA-szám (kötelező az élesítéshez)
SELLER_ADDRESS=           # székhely cím
