# EBC Comfort — .env.example
# Copy to .env.local + fill real values before deploy.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://kdfoaamnmzhrdbrzawtf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                  # public anon key
SUPABASE_SERVICE_ROLE_KEY=eyJ...                       # service_role (NEVER expose to client) — webhook DB writes

# === Site ===
NEXT_PUBLIC_SITE_URL=https://ebc-comfort.netlify.app

# === Stripe (Sprint 3) ===
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...                          # backend: create checkout session
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...         # frontend (if elements used later)
STRIPE_WEBHOOK_SECRET=whsec_...                        # webhook signature verification
# Webhook URL to register at dashboard:
#   https://ebc-comfort.netlify.app/api/stripe/webhook
# Required events: checkout.session.completed, checkout.session.expired,
#                  charge.refunded, charge.refund.updated

# === AI chat (Edge Function — set as Supabase secret, not Next.js env) ===
# ANTHROPIC_API_KEY=sk-ant-api03-...

# === Resend transactional email (Sprint 4) ===
# Dashboard: https://resend.com/api-keys (100 free emails/day)
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=EBC Comfort <noreply@ebc-wellness.eu>

# === RAG embedding (Sprint 5) — Voyage primary, Mistral fallback ===
# Voyage: https://www.voyageai.com/ (200M free tokens)
VOYAGE_API_KEY=pa-...
# Mistral EU fallback: https://console.mistral.ai/
MISTRAL_API_KEY=...
